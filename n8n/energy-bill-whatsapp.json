    },
    "como_configurar": [
      "1. Importe este JSON no N8N via menu Workflows → Import",
      "2. Configure as variáveis de ambiente no N8N (Settings → Variables)",
      "3. Crie a credential 'Evolution API Key' com apikey no header",
      "4. Configure webhook da Evolution API para apontar para o URL do Webhook node",
      "5. Teste enviando uma foto de conta de energia pelo WhatsApp"
    ]
  }
